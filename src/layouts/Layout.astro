---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Welcome to the Roomie Ecosystem - The ultimate set of apps for your room and beyond." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--color-bg: #ffffff; /* White background as requested */
		--color-surface: rgba(255, 255, 255, 0.8);
		--color-surface-hover: rgba(243, 244, 246, 0.8);
		--color-border: rgba(0, 0, 0, 0.08);
		--color-text: #0f172a;
		--color-text-muted: #64748b;
		--color-accent: #3b82f6;
		
		/* Brand colors */
		--color-brand-1: #6366f1;
		--color-brand-2: #ec4899;
		--color-brand-3: #10b981;
		--color-brand-4: #f59e0b;
	}

	html {
		font-family: 'Outfit', sans-serif;
		background-color: var(--color-bg);
		color: var(--color-text);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		overflow-x: hidden;
		position: relative;
	}

	/* Simple light background without heavy animations to keep it clean */
	body::before {
		content: '';
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: #ffffff;
		z-index: -1;
		pointer-events: none;
	}

	/* Utilities */
	.glass-panel {
		background: var(--color-surface);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--color-border);
		border-radius: 24px;
		box-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.05);
	}

	h1, h2, h3, p {
		margin: 0;
	}

	* {
		box-sizing: border-box;
	}
</style>
