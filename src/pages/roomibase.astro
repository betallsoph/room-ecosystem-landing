---
import Layout from '../layouts/Layout.astro';
import { Search, BadgeCheck, MessageCircle } from 'lucide-react';
---

<Layout title="roomiBase - Roomie Ecosystem">
	<main class="container">
		<a href="/" class="back-link">&larr; Back to Ecosystem</a>
		
		<section class="detail-header glass-panel">
			<img src="/assets/logos/roomibase.png" alt="roomiBase Logo" class="detail-logo" />
			<h1 class="title text-gradient-3">roomiBase</h1>
			<p class="description">
				Find the perfect room or roommate. Advanced matchmaking based on lifestyle, habits, and preferences.
			</p>
			<a href="https://findingroom.app" target="_blank" rel="noopener noreferrer" class="detail-cta">
				Truy cập roomiBase &rarr;
			</a>
		</section>

		<section class="features-section">
			<div class="features-list">
				<div class="feature-item">
					<div class="icon-wrapper"><Search size={24} /></div>
					<div class="feature-content">
						<h3>Smart Matchmaking</h3>
						<p>Our algorithm connects you with roommates whose habits, cleanliness, and schedules align with yours.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><BadgeCheck size={24} /></div>
					<div class="feature-content">
						<h3>Verified Listings</h3>
						<p>Browse high-quality, verified room listings to ensure your safety and comfort before moving in.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><MessageCircle size={24} /></div>
					<div class="feature-content">
						<h3>Secure Messaging</h3>
						<p>Chat safely with potential roommates and landlords directly within the platform without sharing personal info too early.</p>
					</div>
				</div>
			</div>
		</section>

		<footer>
			<p>&copy; {new Date().getFullYear()} Roomie Ecosystem. Crafted with Astro by 99%-from-AI Labs.</p>
		</footer>
	</main>
</Layout>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
		animation: fadeUp 0.6s ease-out forwards;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: var(--color-text);
	}

	.detail-header {
		padding: 3rem 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 3rem;
	}

	.detail-logo {
		height: 50px;
		object-fit: contain;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 4px 12px rgba(0,0,0,0.05));
	}

	.title {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1rem;
		display: none;
	}

	.text-gradient-3 {
		background: linear-gradient(135deg, var(--color-brand-3), #34d399);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.description {
		font-size: 1.1rem;
		color: var(--color-text-muted);
		max-width: 550px;
		line-height: 1.6;
		margin-top: 1rem;
		margin-bottom: 2rem;
	}

	.detail-cta {
		display: inline-flex;
		background: var(--color-brand-3);
		color: #ffffff;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
	}

	.detail-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);
	}

	/* Simplified Features List */
	.features-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		max-width: 600px;
		margin: 0 auto;
		padding: 1rem 0;
	}

	.feature-item {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.icon-wrapper {
		color: var(--color-brand-3);
		display: inline-flex;
		padding: 0.8rem;
		background: rgba(16, 185, 129, 0.08);
		border-radius: 12px;
		flex-shrink: 0;
	}

	.feature-content h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin: 0 0 0.4rem 0;
		color: var(--color-text);
	}

	.feature-content p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.6;
		font-size: 0.95rem;
	}

	footer {
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-top: 5rem;
		opacity: 0.6;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
