---
import Layout from '../layouts/Layout.astro';
import { Calendar, CheckCircle, MessageSquare } from 'lucide-react';
---

<Layout title="roomieVerse - Roomie Ecosystem">
	<main class="container">
		<a href="/" class="back-link">&larr; Back to Ecosystem</a>
		
		<section class="detail-header glass-panel">
			<img src="/assets/logos/logo2.png" alt="roomieVerse Logo" class="detail-logo" />
			<h1 class="title text-gradient-1">roomieVerse</h1>
			<p class="description">
				Your digital universe for co-living. We make sharing a living space seamless, organized, and fun.
			</p>
			<a href="https://roomieverse.app" target="_blank" rel="noopener noreferrer" class="detail-cta">
				Truy cập roomieVerse &rarr;
			</a>
		</section>

		<!-- Overview Section -->
		<section class="overview-section">
			<div class="overview-item">
				<h4>Để làm gì?</h4>
				<p>Nền tảng quản lý và kết nối mọi hoạt động trong phòng ở ghép. Giúp chia sẻ thông tin, lịch trình và phân công công việc nhà tự động.</p>
			</div>
			<div class="overview-item">
				<h4>Dành cho ai?</h4>
				<p>Những người đang sống chung (roommates), sinh viên ở ghép, hoặc các nhóm bạn thuê chung căn hộ muốn duy trì không gian sống văn minh.</p>
			</div>
			<div class="overview-item">
				<h4>Giải quyết khó khăn gì?</h4>
				<p>Tránh tình trạng tị nạnh làm việc nhà nhờ tính năng xoay vòng tự động, không còn quên lịch đóng tiền và trôi tin thông báo quan trọng.</p>
			</div>
		</section>

		<section class="features-section">
			<div class="features-list">
				<div class="feature-item">
					<div class="icon-wrapper"><Calendar size={24} /></div>
					<div class="feature-content">
						<h3>Shared Calendar</h3>
						<p>Keep track of apartment events, quiet hours, and when guests are coming over.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><CheckCircle size={24} /></div>
					<div class="feature-content">
						<h3>Chore Management</h3>
						<p>Fair and automated chore rotation so the apartment always stays clean without arguments.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><MessageSquare size={24} /></div>
					<div class="feature-content">
						<h3>Centralized Chat</h3>
						<p>A dedicated space for apartment announcements and daily chatter, separate from your messy personal inboxes.</p>
					</div>
				</div>
			</div>
		</section>

		<footer>
			<p>&copy; {new Date().getFullYear()} Roomie Ecosystem. Crafted with Astro by 99%-from-AI Labs.</p>
		</footer>
	</main>
</Layout>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
		animation: fadeUp 0.6s ease-out forwards;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: var(--color-text);
	}

	.detail-header {
		padding: 3rem 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 1.5rem;
	}

	.detail-logo {
		height: 100px;
		object-fit: contain;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 4px 12px rgba(0,0,0,0.08));
	}

	.title {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.text-gradient-1 {
		background: linear-gradient(135deg, var(--color-brand-1), #a855f7);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.description {
		font-size: 1.1rem;
		color: var(--color-text-muted);
		max-width: 550px;
		line-height: 1.6;
		margin-bottom: 2rem;
	}

	.detail-cta {
		display: inline-flex;
		background: var(--color-brand-1);
		color: #ffffff;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
	}

	.detail-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
	}

	/* Overview Section style */
	.overview-section {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 2rem;
		margin: 3rem 0;
		text-align: left;
	}

	.overview-item {
		border-left: 2px solid var(--color-brand-1);
		padding-left: 1rem;
	}

	.overview-item h4 {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text);
		margin: 0 0 0.5rem 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.overview-item p {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.5;
		margin: 0;
	}

	/* Simplified Features List */
	.features-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		max-width: 600px;
		margin: 0 auto;
		padding: 1rem 0;
	}

	.feature-item {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.icon-wrapper {
		color: var(--color-brand-1);
		display: inline-flex;
		padding: 0.8rem;
		background: rgba(99, 102, 241, 0.08);
		border-radius: 12px;
		flex-shrink: 0;
	}

	.feature-content h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin: 0 0 0.4rem 0;
		color: var(--color-text);
	}

	.feature-content p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.6;
		font-size: 0.95rem;
	}

	footer {
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-top: 5rem;
		opacity: 0.6;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
