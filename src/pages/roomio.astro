---
import Layout from '../layouts/Layout.astro';
import { Receipt, Bell, PieChart } from 'lucide-react';
---

<Layout title="roomio - Roomie Ecosystem">
	<main class="container">
		<a href="/" class="back-link">&larr; Back to Ecosystem</a>
		
		<section class="detail-header glass-panel">
			<img src="/assets/logos/roomio.png" alt="roomio Logo" class="detail-logo" />
			<h1 class="title text-gradient-2">roomio</h1>
			<p class="description">
				The smartest way to handle shared expenses and bills. Never let money ruin a good friendship.
			</p>
			<div class="cta-group">
				<a href="https://roomio.vn" target="_blank" rel="noopener noreferrer" class="detail-cta">
					Truy cập roomio Web &rarr;
				</a>
				<a href="https://t.me/roomiobyantt_bot/roomio" target="_blank" rel="noopener noreferrer" class="detail-cta-secondary">
					Telegram Mini App &rarr;
				</a>
			</div>
		</section>

		<!-- Overview Section -->
		<section class="overview-section">
			<div class="overview-item">
				<h4>Để làm gì?</h4>
				<p>Hệ thống quản lý tài chính và tự động đối soát tiền phòng. Hỗ trợ chia hóa đơn, tự động tạo link thanh toán PayOS và nhắc nhở thân thiện.</p>
			</div>
			<div class="overview-item">
				<h4>Dành cho ai?</h4>
				<p>Các chủ nhà trọ, quản lý tòa nhà chung cư mini (landlord-first) và những bạn trẻ ở ghép cần phân chia chi phí sinh hoạt rõ ràng hàng tháng.</p>
			</div>
			<div class="overview-item">
				<h4>Giải quyết khó khăn gì?</h4>
				<p>Loại bỏ việc tính tiền điện nước thủ công phức tạp, giải quyết sự ngại ngùng khi phải đòi tiền trực tiếp và chống thất thoát dòng tiền.</p>
			</div>
		</section>

		<section class="features-section">
			<div class="features-list">
				<div class="feature-item">
					<div class="icon-wrapper"><Receipt size={24} /></div>
					<div class="feature-content">
						<h3>Split Anything</h3>
						<p>From rent and utilities to that midnight pizza order. Split bills equally or by specific percentages.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><Bell size={24} /></div>
					<div class="feature-content">
						<h3>Smart Reminders</h3>
						<p>Automated, friendly notifications so you never have to awkwardly ask your roommate for money again.</p>
					</div>
				</div>
				
				<div class="feature-item">
					<div class="icon-wrapper"><PieChart size={24} /></div>
					<div class="feature-content">
						<h3>Expense Insights</h3>
						<p>See where your household money is going each month with beautiful charts and summaries.</p>
					</div>
				</div>
			</div>
		</section>

		<footer>
			<p>&copy; {new Date().getFullYear()} Roomie Ecosystem. Crafted with Astro by 99%-from-AI Labs.</p>
		</footer>
	</main>
</Layout>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
		animation: fadeUp 0.6s ease-out forwards;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: var(--color-text);
	}

	.detail-header {
		padding: 3rem 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 1.5rem;
	}

	.detail-logo {
		height: 50px;
		object-fit: contain;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 4px 12px rgba(0,0,0,0.05));
	}

	.title {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1rem;
		display: none;
	}

	.text-gradient-2 {
		background: linear-gradient(135deg, var(--color-brand-2), #f43f5e);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.description {
		font-size: 1.1rem;
		color: var(--color-text-muted);
		max-width: 550px;
		line-height: 1.6;
		margin-top: 1rem;
		margin-bottom: 2rem;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.detail-cta {
		display: inline-flex;
		background: var(--color-brand-2);
		color: #ffffff;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 4px 12px rgba(236, 72, 153, 0.2);
	}

	.detail-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(236, 72, 153, 0.3);
	}

	.detail-cta-secondary {
		display: inline-flex;
		background: #f1f5f9;
		color: #334155;
		border: 1px solid #cbd5e1;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, background-color 0.2s;
	}

	.detail-cta-secondary:hover {
		transform: translateY(-2px);
		background: #e2e8f0;
	}

	/* Overview Section style */
	.overview-section {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 2rem;
		margin: 3rem 0;
		text-align: left;
	}

	.overview-item {
		border-left: 2px solid var(--color-brand-2);
		padding-left: 1rem;
	}

	.overview-item h4 {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text);
		margin: 0 0 0.5rem 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.overview-item p {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.5;
		margin: 0;
	}

	/* Simplified Features List */
	.features-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		max-width: 600px;
		margin: 0 auto;
		padding: 1rem 0;
	}

	.feature-item {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.icon-wrapper {
		color: var(--color-brand-2);
		display: inline-flex;
		padding: 0.8rem;
		background: rgba(236, 72, 153, 0.08);
		border-radius: 12px;
		flex-shrink: 0;
	}

	.feature-content h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin: 0 0 0.4rem 0;
		color: var(--color-text);
	}

	.feature-content p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.6;
		font-size: 0.95rem;
	}

	footer {
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-top: 5rem;
		opacity: 0.6;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
