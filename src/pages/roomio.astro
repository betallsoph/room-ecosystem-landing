---
import Layout from '../layouts/Layout.astro';
import { Receipt, Bell, PieChart } from 'lucide-react';
---

<Layout title="roomio - Roomie Ecosystem">
	<main class="container">
		<a href="/" class="back-link">&larr; Back to Ecosystem</a>
		
		<section class="detail-header glass-panel">
			<img src="/assets/logos/roomio.png" alt="roomio Logo" class="detail-logo" />
			<h1 class="title text-gradient-2">roomio</h1>
			<p class="description">
				The smartest way to handle shared expenses and bills. Never let money ruin a good friendship.
			</p>
			<div class="cta-group">
				<a href="https://roomio.vn" target="_blank" rel="noopener noreferrer" class="detail-cta">
					Truy cập roomio Web &rarr;
				</a>
				<a href="https://t.me/roomiobyantt_bot/roomio" target="_blank" rel="noopener noreferrer" class="detail-cta-secondary">
					Telegram Mini App &rarr;
				</a>
			</div>
		</section>

		<section class="features-section">
			<h2>Key Features</h2>
			<div class="features-grid">
				<div class="feature-card glass-panel">
					<div class="icon-wrapper"><Receipt size={28} /></div>
					<h3>Split Anything</h3>
					<p>From rent and utilities to that midnight pizza order. Split bills equally or by specific percentages.</p>
				</div>
				<div class="feature-card glass-panel">
					<div class="icon-wrapper"><Bell size={28} /></div>
					<h3>Smart Reminders</h3>
					<p>Automated, friendly notifications so you never have to awkwardly ask your roommate for money again.</p>
				</div>
				<div class="feature-card glass-panel">
					<div class="icon-wrapper"><PieChart size={28} /></div>
					<h3>Expense Insights</h3>
					<p>See where your household money is going each month with beautiful charts and summaries.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 3rem 2rem;
		animation: fadeUp 0.6s ease-out forwards;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.back-link:hover {
		color: var(--color-text);
	}

	.detail-header {
		padding: 4rem 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 4rem;
	}

	.detail-logo {
		height: 60px;
		object-fit: contain;
		margin-bottom: 1.5rem;
		filter: drop-shadow(0 4px 12px rgba(0,0,0,0.05));
	}

	.title {
		font-size: 3rem;
		font-weight: 800;
		margin-bottom: 1rem;
		display: none; /* Hidden since logo is a wordmark */
	}

	.text-gradient-2 {
		background: linear-gradient(135deg, var(--color-brand-2), #f43f5e);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.description {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		max-width: 600px;
		line-height: 1.6;
		margin-top: 1rem;
		margin-bottom: 2rem;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.detail-cta {
		display: inline-flex;
		background: var(--color-brand-2);
		color: #ffffff;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 4px 12px rgba(236, 72, 153, 0.2);
	}

	.detail-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(236, 72, 153, 0.3);
	}

	.detail-cta-secondary {
		display: inline-flex;
		background: #f1f5f9;
		color: #334155;
		border: 1px solid #cbd5e1;
		padding: 0.8rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, background-color 0.2s;
	}

	.detail-cta-secondary:hover {
		transform: translateY(-2px);
		background: #e2e8f0;
	}

	.features-section h2 {
		font-size: 2rem;
		margin-bottom: 2rem;
		text-align: center;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.feature-card {
		padding: 2rem;
		background: #ffffff;
		transition: transform 0.3s;
	}

	.feature-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px rgba(236, 72, 153, 0.1);
	}

	.icon-wrapper {
		color: var(--color-brand-2);
		margin-bottom: 1rem;
		display: inline-flex;
		padding: 0.8rem;
		background: rgba(236, 72, 153, 0.1);
		border-radius: 12px;
	}

	.feature-card h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.feature-card p {
		color: var(--color-text-muted);
		line-height: 1.6;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
